# .env.example
# Copy this file to .env and fill in the actual values

# Optional: Default timezone for the application
# TZ=Asia/Tokyo

# Optional: Public site URL and support contact shown in the app (footer,
# feedback button mailto link, etc). Each fork/self-hosted deployment should
# set these to its own domain/address; both fall back to generic placeholders
# if unset so the OSS template doesn't ship with any one operator's identity.
# NEXT_PUBLIC_APP_URL=https://your-domain.example.com
# NEXT_PUBLIC_FEEDBACK_EMAIL=feedback@your-domain.example.com

# Optional: Configuration for Campus Square integration
# Set this to "true" to enable the integration in the UI. 
# NEXT_PUBLIC_ENABLE_CAMPUS_SQUARE=true
#
# AI Scheduling (OpenCode Go)
OPENCODE_API_KEY=your_opencode_api_key_here
NEXT_PUBLIC_ENABLE_AI_SCHEDULING=true

# CAMPUS_SQUARE_LOGIN_WFID=nwf_PTW0000002_login
# CAMPUS_SQUARE_CALENDAR_FLOWID=POW2401000-flow
# CAMPUS_SQUARE_TIMEZONE_OFFSET=+09:00

# Database Configuration
# D1 database ID is configured in wrangler.jsonc instead of here, but any secret 
# variables can be added here or via `wrangler secret put`.

# Google Calendar OAuth (Cloud)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/auth/callback

# Encryption key for Google OAuth tokens at rest (AES-256-GCM).
# Must be 32 random bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# If unset, tokens are stored in plaintext (development only — set this in production).
# TOKEN_ENC_KEY=

# Encryption key for participant PII at rest (name/comment/notification email),
# AES-256-GCM. Same format/generation as TOKEN_ENC_KEY above, but must be a
# DIFFERENT key. If unset, PII is stored in plaintext (development only —
# set this in production).
# PII_ENC_KEY=

# Bearer token required by operator-only maintenance endpoints
# (e.g. /api/admin/backfill-pii, used when rotating PII_ENC_KEY). Generate with:
#   openssl rand -hex 32
# Keep this secret; anyone with it can trigger those endpoints.
# ADMIN_OPS_TOKEN=

# Wana (Sentry-compatible) error tracker DSN.
# Frontend and backend both report errors here. The public key is part of the
# DSN and is meant to be public, so NEXT_PUBLIC_ (client-inlined) is fine.
# If unset, error reporting is a no-op. Point this at your own Sentry/Wana
# project — do not reuse another operator's DSN.
# NEXT_PUBLIC_WANA_DSN=https://<publicKey>@ingest.your-error-tracker.example.com/<projectId>
