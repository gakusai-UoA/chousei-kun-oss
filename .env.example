# .env.example
# Copy this file to .env and fill in the actual values

# Optional: Default timezone for the application
# TZ=Asia/Tokyo

# Optional: Configuration for Campus Square integration
# Set this to "true" to enable the integration in the UI. 
# NEXT_PUBLIC_ENABLE_CAMPUS_SQUARE=true
#
# AI Scheduling (OpenCode Go)
OPENCODE_API_KEY=your_opencode_api_key_here
NEXT_PUBLIC_ENABLE_AI_SCHEDULING=true

# CAMPUS_SQUARE_LOGIN_WFID=nwf_PTW0000002_login
# CAMPUS_SQUARE_CALENDAR_FLOWID=POW2401000-flow
# CAMPUS_SQUARE_TIMEZONE_OFFSET=+09:00

# Database Configuration
# D1 database ID is configured in wrangler.jsonc instead of here, but any secret 
# variables can be added here or via `wrangler secret put`.

# Google Calendar OAuth (Cloud)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/auth/callback

# Encryption key for Google OAuth tokens at rest (AES-256-GCM).
# Must be 32 random bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# If unset, tokens are stored in plaintext (development only — set this in production).
# TOKEN_ENC_KEY=

# Wana (Sentry-compatible) error tracker DSN.
# Frontend and backend both report errors here. The public key is part of the
# DSN and is meant to be public, so NEXT_PUBLIC_ (client-inlined) is fine.
# If unset, error reporting is a no-op.
# NEXT_PUBLIC_WANA_DSN=https://<publicKey>@ingest.wana.shakenokiri.me/<projectId>
